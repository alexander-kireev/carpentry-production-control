# Copy to .env and adjust for your machine. .env is gitignored — never commit real secrets.
SECRET_KEY=change-me-generate-a-real-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.dev

# Database (PostgreSQL only — SQLite is never used, including in tests).
# For host runs use DB_HOST=localhost; Docker Compose overrides DB_HOST to the
# "db" service name automatically. DB_PASSWORD here is a local dev value only.
DB_NAME=carpentry_production_control
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
